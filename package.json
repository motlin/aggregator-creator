{
	"name": "aggregator-creator",
	"version": "0.0.0",
	"description": "CLI for managing Maven repositories and creating aggregator POMs",
	"keywords": [
		"aggregator",
		"cli",
		"maven",
		"oclif",
		"pom"
	],
	"homepage": "https://github.com/motlin/aggregator-creator",
	"bugs": "https://github.com/motlin/aggregator-creator/issues",
	"license": "Apache 2.0",
	"author": "Craig P. Motlin",
	"repository": "motlin/aggregator-creator",
	"bin": {
		"aggregator": "./bin/run.js"
	},
	"files": [
		"./bin",
		"./dist",
		"./oclif.manifest.json"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "shx rm -rf dist && tsc -b",
		"oxlint": "vp lint . --fix",
		"oxlint:ci": "vp lint . --format github",
		"fmt": "vp fmt",
		"fmt:ci": "vp fmt --check",
		"fallow": "fallow fix --yes",
		"fallow:ci": "fallow dead-code",
		"typecheck": "tsc --noEmit",
		"postpack": "shx rm -f oclif.manifest.json",
		"prepack": "oclif manifest && oclif readme",
		"test": "CHAI_TRUNCATE_THRESHOLD=0 mocha --forbid-only \"test/**/*.test.ts\"",
		"test:run": "CHAI_TRUNCATE_THRESHOLD=0 mocha --forbid-only \"test/**/*.test.ts\"",
		"version": "oclif readme && git add README.md",
		"prepublishOnly": "pnpm run build && pnpm test",
		"release:patch": "npm version patch && npm publish",
		"release:minor": "npm version minor && npm publish",
		"release:major": "npm version major && npm publish",
		"prepare": "vp config"
	},
	"dependencies": {
		"@oclif/core": "4.11.6",
		"@oclif/plugin-help": "6.2.52",
		"chalk": "5.6.2",
		"execa": "9.6.1",
		"fs-extra": "11.3.5",
		"inquirer": "14.0.2",
		"xml2js": "0.6.2",
		"xmlbuilder2": "4.0.3",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@oclif/test": "4.1.20",
		"@types/chai": "5.2.3",
		"@types/fs-extra": "11.0.4",
		"@types/mocha": "10.0.10",
		"@types/node": "26.0.0",
		"@types/sinon": "21.0.1",
		"@types/xml2js": "0.4.14",
		"chai": "6.2.2",
		"fallow": "^2.95.0",
		"markdownlint-cli2": "^0.22.1",
		"mocha": "11.7.6",
		"oclif": "4.23.20",
		"shx": "0.4.0",
		"sinon": "22.0.0",
		"ts-node": "10.9.2",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"oclif": {
		"bin": "aggregator",
		"commands": "./dist/commands",
		"dirname": "aggregator",
		"plugins": [
			"@oclif/plugin-help"
		],
		"topicSeparator": " ",
		"topics": {
			"aggregator": {
				"description": "Maven aggregator POM management"
			},
			"repo": {
				"description": "Repository management commands"
			}
		}
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"packageManager": "pnpm@11.1.1"
}
